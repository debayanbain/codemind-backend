{
  "name": "CodeMind",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build api-gateway && nest build orchestrator && nest build agent-worker && nest build synthesizer",
    "build:api-gateway": "nest build api-gateway",
    "build:orchestrator": "nest build orchestrator",
    "build:agent-worker": "nest build agent-worker",
    "build:synthesizer": "nest build synthesizer",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "start:dev": "nest start api-gateway",
    "start:api-gateway:dev": "nest start api-gateway --watch",
    "start:orchestrator": "nest start orchestrator",
    "start:orchestrator:dev": "nest start orchestrator --watch",
    "start:agent-worker": "nest start agent-worker",
    "start:agent-worker:dev": "nest start agent-worker --watch",
    "start:synthesizer": "nest start synthesizer",
    "start:synthesizer:dev": "nest start synthesizer --watch",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
    "docker:start:dev": "docker compose -f docker-compose.dev.yml up --build -d redis rabbitmq migrate orchestrator agent-worker synthesizer",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:prod": "docker compose up --build -d",
    "docker:prod:down": "docker compose down",
    "logs:api-gateway": "tail -f logs/api-gateway-$(date +%Y-%m-%d).log",
    "logs:orchestrator": "tail -f logs/orchestrator-$(date +%Y-%m-%d).log",
    "logs:agent-worker": "tail -f logs/agent-worker-$(date +%Y-%m-%d).log",
    "logs:synthesizer": "tail -f logs/synthesizer-$(date +%Y-%m-%d).log",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@colbymchenry/codegraph": "^1.1.6",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.0.1",
    "@nestjs/websockets": "^11.0.1",
    "@prisma/client": "^6.2.1",
    "@terrastruct/d2": "^0.1.33",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.4.1",
    "md-to-pdf": "^5.2.4",
    "nest-winston": "^1.10.2",
    "openai": "^6.45.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "tar": "^7.4.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/amqplib": "^0.10.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/apps",
      "<rootDir>/libs"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@app/common$": "<rootDir>/libs/common/src",
      "^@app/common/(.*)$": "<rootDir>/libs/common/src/$1"
    },
    "collectCoverageFrom": [
      "apps/**/*.(t|j)s",
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
