// Matches CLAUDE.md Section 7's table/column names via @map/@@map — model
// and field names stay idiomatic camelCase in TypeScript, the underlying
// Postgres schema stays snake_case.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase Supavisor / pgbouncer, port 6543) — what the
  // 4 long-running app processes use for normal queries.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) — required by `prisma migrate`, which
  // can't run through a transaction pooler.
  directUrl = env("DIRECT_URL")
}

enum JobStatus {
  pending
  running
  done
  failed
}

enum AgentType {
  architecture
  security
  dependency
  quality
  docs
}

enum AgentRunStatus {
  success
  failed
}

model User {
  id String @id @default(uuid())
  // Clerk is the identity provider now. clerkId is the stable primary key we
  // key everything to; GitHub is an *optional* linked account (a user can sign
  // in with Google and connect GitHub later), so the github_* columns are
  // nullable and populated only once the GitHub OAuth token is fetched.
  clerkId                    String   @unique @map("clerk_id")
  email                      String?  @map("email")
  // Display name from Clerk (first + last, or Google profile name). Nullable:
  // a GitHub-only user may have none, and we fall back to username/email.
  name                       String?  @map("name")
  githubId                   String?  @unique @map("github_id")
  githubAccessTokenEncrypted String?  @map("github_access_token_encrypted")
  githubUsername             String?  @map("github_username")
  avatarUrl                  String?  @map("avatar_url")
  createdAt                  DateTime @default(now()) @map("created_at")
  // Bumped on every sync (webhook or lazy refresh). getOrCreateUser uses it to
  // re-pull a profile from Clerk at most once per TTL — the backstop for a
  // permanently-lost user.updated webhook. @default(now()) so the column can be
  // added NOT NULL to the existing row.
  updatedAt                  DateTime @default(now()) @updatedAt @map("updated_at")

  jobs   Job[]
  shares ReportShare[]

  @@map("users")
}

model Job {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  repoFullName String    @map("repo_full_name")
  status       JobStatus @default(pending)
  createdAt    DateTime  @default(now()) @map("created_at")
  completedAt  DateTime? @map("completed_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentResults AgentResult[]
  report       Report?

  @@index([userId])
  @@map("jobs")
}

model AgentResult {
  id         String         @id @default(uuid())
  jobId      String         @map("job_id")
  agentType  AgentType      @map("agent_type")
  rawOutput  Json           @default("{}") @map("raw_output")
  tokensUsed Json           @default("{\"input\":0,\"output\":0}") @map("tokens_used")
  status     AgentRunStatus
  durationMs Int?           @map("duration_ms")
  error      String?
  createdAt  DateTime       @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("agent_results")
}

model Report {
  id              String   @id @default(uuid())
  jobId           String   @unique @map("job_id")
  markdownContent String   @map("markdown_content")
  // RenderedDiagram[] — each diagram's source (D2 DSL / chart data JSON) plus
  // the SVG the synthesizer rendered from it. Stored, not regenerated: the
  // exporter and the frontend embed these strings directly, so neither needs a
  // diagram renderer of its own. Defaulted so reports written before the D2
  // migration still read back cleanly.
  diagrams        Json     @default("[]")
  // SonnetSynthesisOutput — executiveSummary, recommendations[],
  // overallHealthScore. Also rendered into markdownContent, but persisted
  // structurally so the dashboard reads numbers instead of scraping prose.
  // Nullable: reports written before this column exist without it.
  synthesis       Json?
  totalTokens     Int      @default(0) @map("total_tokens")
  createdAt       DateTime @default(now()) @map("created_at")

  job    Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  shares ReportShare[]

  @@map("reports")
}

/**
 * A view-only link to someone else's report. The token is the only capability —
 * it must be unguessable (32 random bytes, base64url). Viewing still requires a
 * CodeMind session: the token grants access to the report, not anonymity.
 *
 * Revocation is a timestamp, not a delete, so a revoked link stays traceable.
 */
model ReportShare {
  id          String    @id @default(uuid())
  reportId    String    @map("report_id")
  token       String    @unique
  createdById String    @map("created_by_id")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  report    Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_shares")
}
