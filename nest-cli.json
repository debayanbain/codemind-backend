{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/api-gateway",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
  },
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "orchestrator": {
      "type": "application",
      "root": "apps/orchestrator",
      "entryFile": "main",
      "sourceRoot": "apps/orchestrator/src",
      "compilerOptions": {
        "tsConfigPath": "apps/orchestrator/tsconfig.app.json"
      }
    },
    "agent-worker": {
      "type": "application",
      "root": "apps/agent-worker",
      "entryFile": "main",
      "sourceRoot": "apps/agent-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/agent-worker/tsconfig.app.json"
      }
    },
    "synthesizer": {
      "type": "application",
      "root": "apps/synthesizer",
      "entryFile": "main",
      "sourceRoot": "apps/synthesizer/src",
      "compilerOptions": {
        "tsConfigPath": "apps/synthesizer/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    }
  }
}
